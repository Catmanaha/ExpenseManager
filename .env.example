# SQL Server connection used by Spring Boot.
DATABASE_URL=jdbc:sqlserver://localhost:1433;databaseName=expense_manager;encrypt=true;trustServerCertificate=true
DATABASE_USERNAME=sa
DATABASE_PASSWORD=REPLACE_WITH_A_LOCAL_PASSWORD

# Use a randomly generated secret of at least 32 characters.
JWT_SECRET=REPLACE_WITH_A_RANDOM_SIGNING_SECRET_OF_AT_LEAST_32_CHARACTERS
JWT_ACCESS_TOKEN_LIFETIME=PT2H
